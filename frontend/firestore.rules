rules_version = '2';

service cloud.firestore {
  function hasValidBlogFields() {
    return request.resource.data.keys().hasAll([
      'title',
      'slug',
      'shortDescription',
      'content',
      'category',
      'authorName',
      'authorUid',
      'coverImageUrl',
      'published'
    ])
    && request.resource.data.title is string
    && request.resource.data.slug is string
    && request.resource.data.shortDescription is string
    && request.resource.data.content is string
    && request.resource.data.category is string
    && request.resource.data.authorName is string
    && request.resource.data.authorUid is string
    && request.resource.data.coverImageUrl is string
    && request.resource.data.published is bool;
  }

  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(data) {
    return isSignedIn() && data.authorUid == request.auth.uid;
  }

  match /databases/{database}/documents {
    match /blogs/{blogId} {
      allow read: if resource.data.published == true || isOwner(resource.data);
      allow create: if isSignedIn()
        && hasValidBlogFields()
        && request.resource.data.authorUid == request.auth.uid;
      allow update: if isOwner(resource.data)
        && hasValidBlogFields()
        && request.resource.data.authorUid == resource.data.authorUid;
      allow delete: if isOwner(resource.data);
    }
  }
}
